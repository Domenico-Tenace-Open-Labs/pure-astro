---
import Layout from "../layouts/Layout.astro";
const pageTitle = "Pure Astro";
const pageDescription = "Simple blog template made with Astro and pure CSS";
---

<Layout pageTitle={pageTitle} pageDescription={pageDescription}>
  <div class="gif">
    <img
      src="/images/profile.png"
      role="presentation"
      width="130"
      height="130"
      class="profile__image"
      decoding="async"
    />
  </div>
  <div class="center">
    <h1>Pure Astro</h1>
    <span class="badge">Software Developer</span>
  </div>
